@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Categories";
}

<h1>Categories</h1>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Description</th>
        </tr>
    </thead>
    <tbody>
@foreach(var c in Model)
{
    <tr>
        <td>@c.CategoryID</td>
        <td>@c.CategoryName</td>
        <td>@c.Description</td>
    </tr>
}
            </table>
        </div>
    </div>
</div>
