@model BaseIntroductionDotNetMentoring.Helpers.ProductInput

@{
    ViewData["Title"] = "Edit Product";
}

<div class="card">
    <div class="card-body">
        <h1 class="card-title">Edit Product</h1>

        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="StockQuantity" class="form-label"></label>
        <input asp-for="StockQuantity" class="form-control" />
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">Category</label>
        <select asp-for="CategoryId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(ViewBag.Categories, "CategoryID", "CategoryName"))">
            <option value="0">-- select --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="SupplierId" class="form-label">Supplier</label>
        <select asp-for="SupplierId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(ViewBag.Suppliers, "SupplierID", "CompanyName"))">
            <option value="">-- none --</option>
        </select>
        <span asp-validation-for="SupplierId" class="text-danger"></span>
    </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Products" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
